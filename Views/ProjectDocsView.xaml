<UserControl x:Class="AGenerator.Views.ProjectDocsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AGenerator.ViewModels"
             xmlns:converters="clr-namespace:AGenerator.Converters"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ProjectDocsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>

        <!-- Стиль для ячеек с переносом текста -->
        <Style x:Key="WrappingCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить"
                        Command="{Binding AddNewProjectDocCommand}"
                        Style="{StaticResource PrimaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"/>
                <Button Content="✏️ Изменить"
                        Command="{Binding EditSelectedProjectDocCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedProjectDoc, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Удалить"
                        Command="{Binding DeleteSelectedProjectDocCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedProjectDoc, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🔄 Обновить"
                        Command="{Binding RefreshAsyncCommand}"
                        Style="{StaticResource GlassButton}"
                        Padding="10,5"/>
            </StackPanel>
        </Border>

        <!-- Поиск -->
        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource GlassTextBox}"
                 Margin="0,0,0,10"
                 Padding="5"
                 ToolTip="Поиск по шифру или названию"/>

        <!-- Таблица проектной документации -->
        <DataGrid Grid.Row="2"
                  x:Name="ProjectDocsDataGrid"
                  ItemsSource="{Binding ProjectDocs}"
                  SelectedItem="{Binding SelectedProjectDoc}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  SelectionMode="Single"
                  MouseDoubleClick="ProjectDocsDataGrid_MouseDoubleClick"
                  MouseLeftButtonUp="ProjectDocsDataGrid_MouseLeftButtonUp"
                  behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True"
                  Style="{StaticResource GlassDataGrid}">
            <DataGrid.Resources>
                <!-- Стиль для TextBlock в ячейках — перенос текста + автоматическая высота -->
                <Style TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Шифр" Width="150" Binding="{Binding Code}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Название раздела" Binding="{Binding Name}" Width="250"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Листы" Width="120" Binding="{Binding Sheets}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Организация" Width="180" Binding="{Binding Organization}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="ГИП" Width="150" Binding="{Binding GIP}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <!-- Колонка файла проекта -->
                <DataGridTemplateColumn Header="Файл" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📎"
                                    ToolTip="{Binding FileName, Mode=OneWay}"
                                    Command="{Binding DataContext.OpenProjectFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Visibility="{Binding FileName, Mode=OneWay, Converter={StaticResource NullToBoolConverter}, ConverterParameter=Inverted}"
                                    Padding="2"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Модальное окно редактирования (Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Background="#F0FFFFFF"
                    Width="580"
                    MaxHeight="650"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="25"
                    CornerRadius="15"
                    Margin="20"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    Effect="{StaticResource GlassShadow}">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Заголовок с кнопкой закрытия -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Проектная документация"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Width="32" Height="32"
                                    FontSize="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Закрыть"/>
                        </Grid>

                        <TextBlock Text="Шифр раздела:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProjectDoc.Code, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <TextBlock Text="Название раздела:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProjectDoc.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <TextBlock Text="Номера листов:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProjectDoc.Sheets, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"
                                 ToolTip="Например: л.4, 5, 7"/>

                        <TextBlock Text="Проектная организация:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProjectDoc.Organization, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <TextBlock Text="ГИП (Главный инженер проекта):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProjectDoc.GIP, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,15" Padding="5"/>

                        <!-- ==================== ЗОНА ПРИКРЕПЛЕНИЯ ФАЙЛА ПРОЕКТА ==================== -->
                        <TextBlock Text="📎 Файл проекта:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border x:Name="ProjectFileDropZone"
                                BorderBrush="#CCC" BorderThickness="2"
                                Padding="15" Margin="0,0,0,12"
                                CornerRadius="5"
                                AllowDrop="True"
                                DragOver="ProjectFileDropZone_DragOver"
                                Drop="ProjectFileDropZone_Drop"
                                Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="Перетащите файл сюда или нажмите кнопку:"
                                           Foreground="#666" FontSize="12" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📎 Прикрепить файл"
                                            Command="{Binding AttachProjectFileCommand}"
                                            Style="{StaticResource GlassButton}"
                                            Padding="10,5" Margin="0,0,10,0"/>
                                    <Button Content="🗑️ Удалить"
                                            Command="{Binding RemoveProjectFileCommand}"
                                            Style="{StaticResource SecondaryGlassButton}"
                                            Padding="10,5"
                                            Visibility="{Binding HasProjectFile, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="Green"
                                           Visibility="{Binding HasProjectFile, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="✅ Прикреплён: "/>
                                    <Run Text="{Binding EditingProjectDoc.FileName, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="💾 Сохранить"
                                    Command="{Binding SaveProjectDocCommand}"
                                    Style="{StaticResource PrimaryGlassButton}"
                                    Padding="15,8"
                                    Margin="0,0,10,0"
                                    IsDefault="True"/>
                            <Button Content="❌ Отмена"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryGlassButton}"
                                    Padding="15,8"
                                    IsCancel="True"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
