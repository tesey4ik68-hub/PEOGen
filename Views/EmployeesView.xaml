<UserControl x:Class="AGenerator.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AGenerator.ViewModels"
             xmlns:models="clr-namespace:AGenerator.Models"
             xmlns:converters="clr-namespace:AGenerator.Converters"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:EmployeesViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:RepresentativeTypeToStringConverter x:Key="RoleToStringConverter"/>

        <!-- DataTemplate для отображения ролей в ComboBox -->
        <DataTemplate x:Key="RoleItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource RoleToStringConverter}}"/>
        </DataTemplate>

        <!-- Стиль для ячеек с переносом текста -->
        <Style x:Key="WrappingCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Контекстное меню таблицы -->
        <ContextMenu x:Key="DataGridContextMenu">
            <MenuItem Header="✏️ Редактировать"
                      Command="{Binding PlacementTarget.DataContext.EditSelectedEmployeeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="📋 Копировать"
                      Command="{Binding PlacementTarget.DataContext.CopyEmployeeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <Separator/>
            <MenuItem Header="🗑️ Удалить"
                      Command="{Binding PlacementTarget.DataContext.DeleteSelectedEmployeeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <Separator/>
            <MenuItem Header="🔄 Обновить"
                      Command="{Binding PlacementTarget.DataContext.RefreshAsyncCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить"
                        Command="{Binding AddNewEmployeeCommand}"
                        Style="{StaticResource PrimaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"/>
                <Button Content="✏️ Изменить"
                        Command="{Binding EditSelectedEmployeeCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedEmployee, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Удалить"
                        Command="{Binding DeleteSelectedEmployeeCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedEmployee, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🔄 Обновить"
                        Command="{Binding RefreshAsyncCommand}"
                        Style="{StaticResource GlassButton}"
                        Padding="10,5"/>
            </StackPanel>
        </Border>

        <!-- Поиск -->
        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource GlassTextBox}"
                 Margin="0,0,0,10"
                 Padding="5"
                 ToolTip="Поиск по ФИО"/>

        <!-- Таблица сотрудников -->
        <DataGrid Grid.Row="2"
                  x:Name="EmployeesDataGrid"
                  ItemsSource="{Binding Employees}"
                  SelectedItem="{Binding SelectedEmployee}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  MouseDoubleClick="EmployeesDataGrid_MouseDoubleClick"
                  MouseLeftButtonUp="EmployeesDataGrid_MouseLeftButtonUp"
                  ColumnReordered="EmployeesDataGrid_ColumnReordered"
                  behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True"
                  ContextMenu="{StaticResource DataGridContextMenu}"
                  Style="{StaticResource GlassDataGrid}">
            <DataGrid.Resources>
                <!-- Стиль для TextBlock в ячейках — перенос текста + автоматическая высота -->
                <Style TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Роль" Width="110"
                                    Binding="{Binding Role, Converter={StaticResource RoleToStringConverter}}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="160"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="130"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Организация" Binding="{Binding OrganizationName}" Width="120"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Приказ №" Binding="{Binding OrderNumber}" Width="70"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Дата приказа" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="НРС №" Binding="{Binding NrsNumber}" Width="90"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding WorkStartDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding WorkEndDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <!-- Колонка файла приказа -->
                <DataGridTemplateColumn Header="Файл" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📎"
                                    ToolTip="{Binding OrderFileName, Mode=OneWay}"
                                    Command="{Binding DataContext.OpenOrderFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Visibility="{Binding OrderFileName, Mode=OneWay, Converter={StaticResource NullToBoolConverter}, ConverterParameter=Inverted}"
                                    Padding="2"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Модальное окно редактирования (Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Background="#F0FFFFFF"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    Width="620"
                    MaxHeight="750"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="25"
                    CornerRadius="15"
                    Margin="20"
                    Effect="{StaticResource GlassShadow}">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Заголовок с кнопкой закрытия -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Сотрудник"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Width="32" Height="32"
                                    FontSize="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Закрыть"/>
                        </Grid>

                        <TextBlock Text="Роль:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ComboBox SelectedItem="{Binding EditingEmployee.Role}" Margin="0,0,0,12"
                                  Style="{StaticResource GlassComboBox}"
                                  ItemTemplate="{StaticResource RoleItemTemplate}">
                            <models:RepresentativeType>SK_Zakazchika</models:RepresentativeType>
                            <models:RepresentativeType>GenPodryadchik</models:RepresentativeType>
                            <models:RepresentativeType>SK_GenPodryadchika</models:RepresentativeType>
                            <models:RepresentativeType>Podryadchik</models:RepresentativeType>
                            <models:RepresentativeType>AvtorskiyNadzor</models:RepresentativeType>
                            <models:RepresentativeType>InoeLico</models:RepresentativeType>
                        </ComboBox>

                        <TextBlock Text="ФИО:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingEmployee.FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <TextBlock Text="Должность:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingEmployee.Position, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <TextBlock Text="Организация:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingEmployee.OrganizationName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5"/>

                        <!-- Приказ -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Приказ №:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding EditingEmployee.OrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource GlassTextBox}"
                                         Padding="5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Дата приказа:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DatePicker SelectedDate="{Binding EditingEmployee.OrderDate}"
                                            HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- НРС -->
                        <TextBlock Text="НРС (Национальный реестр специалистов):" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Идентификационный номер:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding EditingEmployee.NrsNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource GlassTextBox}"
                                         Padding="5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Дата НРС:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DatePicker SelectedDate="{Binding EditingEmployee.NrsDate}"
                                            HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Даты работы -->
                        <TextBlock Text="Период работы:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Дата начала:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DatePicker SelectedDate="{Binding EditingEmployee.WorkStartDate}"
                                            HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Дата окончания:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <DatePicker SelectedDate="{Binding EditingEmployee.WorkEndDate}"
                                            HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Организация в акте -->
                        <CheckBox Content="Включить организацию в акт"
                                  IsChecked="{Binding EditingEmployee.IncludeOrganizationInAct}"
                                  FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Реквизиты организации:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingEmployee.OrganizationRequisites, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12" Padding="5" AcceptsReturn="True" Height="60"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                        <!-- ==================== ЗОНА ПРИКРЕПЛЕНИЯ ФАЙЛА ПРИКАЗА ==================== -->
                        <TextBlock Text="📎 Файл приказа:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border x:Name="OrderDropZone"
                                BorderBrush="#CCC" BorderThickness="2"
                                Padding="15" Margin="0,0,0,12"
                                CornerRadius="5"
                                AllowDrop="True"
                                DragOver="OrderDropZone_DragOver"
                                Drop="OrderDropZone_Drop"
                                Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="Перетащите файл сюда или нажмите кнопку:"
                                           Foreground="#666" FontSize="12" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📎 Прикрепить приказ"
                                            Command="{Binding AttachOrderFileCommand}"
                                            Style="{StaticResource GlassButton}"
                                            Padding="10,5" Margin="0,0,10,0"/>
                                    <Button Content="🗑️ Удалить"
                                            Command="{Binding RemoveOrderFileCommand}"
                                            Style="{StaticResource SecondaryGlassButton}"
                                            Padding="10,5"
                                            Visibility="{Binding HasTempOrderFile, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <!-- Временный файл (только выбран) -->
                                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="Orange"
                                           Visibility="{Binding HasTempOrderFile, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="⏳ Выбран (будет сохранён): "/>
                                    <Run Text="{Binding OrderFileDisplayName, Mode=OneWay}"/>
                                </TextBlock>
                                <!-- Сохранённый файл (уже в БД) -->
                                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="Green"
                                           Visibility="{Binding HasSavedOrderFile, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="✅ Прикреплён: "/>
                                    <Run Text="{Binding OrderFileDisplayName, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="💾 Сохранить"
                                    Command="{Binding SaveEmployeeCommand}"
                                    Style="{StaticResource PrimaryGlassButton}"
                                    Padding="15,8"
                                    Margin="0,0,10,0"
                                    IsDefault="True"/>
                            <Button Content="❌ Отмена"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryGlassButton}"
                                    Padding="15,8"
                                    IsCancel="True"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
