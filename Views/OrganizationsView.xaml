<UserControl x:Class="AGenerator.Views.OrganizationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар (Glass) -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить" Command="{Binding AddNewOrganizationCommand}"
                        Style="{StaticResource PrimaryGlassButton}" Margin="0,0,8,0"/>
                <Button Content="🗑️ Удалить" Command="{Binding DeleteSelectedOrganizationCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        IsEnabled="{Binding SelectedOrganization, Converter={StaticResource NullToBoolConverter}}"
                        Margin="0,0,8,0"/>
                <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>

                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource GlassTextBox}"
                         ToolTip="Поиск по наименованию"/>
            </StackPanel>
        </Border>

        <!-- Таблица организаций -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="OrganizationsDataGrid"
                      ItemsSource="{Binding Organizations}"
                      SelectedItem="{Binding SelectedOrganization}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      AlternatingRowBackground="#F9F9F9"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Disabled"
                      CellEditEnding="OrganizationsDataGrid_CellEditEnding"
                      behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True">

                <DataGrid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Наименование -->
                    <DataGridTextColumn Header="Наименование" Width="250"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Краткое наименование -->
                    <DataGridTextColumn Header="Краткое имя" Width="150"
                                        Binding="{Binding ShortName, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Реквизиты -->
                    <DataGridTextColumn Header="Реквизиты" Width="400"
                                        Binding="{Binding Requisites, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Активность -->
                    <DataGridCheckBoxColumn Header="Активна" Width="80"
                                            Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Дата создания -->
                    <DataGridTextColumn Header="Дата создания" Width="120"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" 
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
