<UserControl x:Class="AGenerator.Views.OrganizationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:AGenerator.Models"
             xmlns:converters="clr-namespace:AGenerator.Converters"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:OrganizationRoleToStringConverter x:Key="OrganizationRoleToStringConverter"/>
        <ObjectDataProvider x:Key="OrganizationRoles" MethodName="GetValues" ObjectType="{x:Type models:OrganizationRole}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:OrganizationRole"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Стиль для ячеек с переносом текста -->
        <Style x:Key="WrappingCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар (Glass) -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить" Command="{Binding AddNewOrganizationCommand}"
                        Style="{StaticResource PrimaryGlassButton}" Margin="0,0,8,0"/>
                <Button Content="🗑️ Удалить" Command="{Binding DeleteSelectedOrganizationCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        IsEnabled="{Binding SelectedOrganization, Converter={StaticResource NullToBoolConverter}}"
                        Margin="0,0,8,0"/>
                <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>

                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource GlassTextBox}"
                         ToolTip="Поиск по наименованию"/>
            </StackPanel>
        </Border>

        <!-- Таблица организаций -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="OrganizationsDataGrid"
                      ItemsSource="{Binding Organizations}"
                      SelectedItem="{Binding SelectedOrganization}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      AlternatingRowBackground="#F9F9F9"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Auto"
                      CellEditEnding="OrganizationsDataGrid_CellEditEnding"
                      behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True">

                <DataGrid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Роль организации -->
                    <DataGridTemplateColumn Header="Роль" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Role, Converter={StaticResource OrganizationRoleToStringConverter}}" Padding="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding Source={StaticResource OrganizationRoles}}"
                                        SelectedItem="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource GlassComboBox}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Наименование -->
                    <DataGridTextColumn Header="Наименование" Width="200"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Реквизиты -->
                    <DataGridTextColumn Header="Реквизиты" Width="250"
                                        Binding="{Binding Requisites, UpdateSourceTrigger=PropertyChanged}"
                                        ElementStyle="{StaticResource WrappingCellText}"/>

                    <!-- Активность -->
                    <DataGridCheckBoxColumn Header="Активна" Width="70"
                                            Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Дата создания -->
                    <DataGridTextColumn Header="Дата создания" Width="100"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" 
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
