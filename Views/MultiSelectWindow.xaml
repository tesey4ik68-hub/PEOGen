<Window x:Class="AGenerator.Views.MultiSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="550" Width="900"
        WindowStartupLocation="CenterOwner"
        MinHeight="400" MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <!-- Внешний контейнер с тенью -->
    <Border Background="Transparent" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="25" ShadowDepth="0"/>
        </Border.Effect>

        <!-- Основной контейнер с закругленными краями -->
        <Border Background="{DynamicResource MainGradient}" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ШАПКА (перетаскиваемая) -->
                <Border Grid.Row="0" Background="{DynamicResource GlassBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Заголовок -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="22" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding WindowTitle}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Кнопки управления окном -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="─" Width="32" Height="32" FontSize="14"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Click="Minimize_Click" ToolTip="Свернуть">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#20000000"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✕" Width="32" Height="32" FontSize="14"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Click="Close_Click" ToolTip="Закрыть">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E81123"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Основной контент -->
                <Border Grid.Row="1" Background="#50FFFFFF" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Поиск -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Width="300" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource GlassTextBox}"
                                     ToolTip="Поиск по названию"/>
                        </StackPanel>

                        <!-- Два списка + кнопки -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левый список: доступные элементы -->
                            <Border Grid.Column="0" Background="#60FFFFFF" CornerRadius="8" Padding="8" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Доступные" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <ListBox Grid.Row="1" x:Name="AvailableListBox"
                                             ItemsSource="{Binding AvailableItems}"
                                             SelectionMode="Extended"
                                             Background="Transparent" BorderThickness="0"
                                             Padding="2"
                                             Foreground="{DynamicResource TextPrimaryBrush}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Margin" Value="0,1"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="#80FFFFFF"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#60FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- Кнопки навигации -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Button Content="▶" Width="40" Height="36" Margin="0,4"
                                        FontWeight="Bold" FontSize="14"
                                        Command="{Binding AddSelectedCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=AvailableListBox}"
                                        ToolTip="Добавить выбранные"
                                        Style="{StaticResource GlassButton}"
                                        Cursor="Hand"/>
                                <Button Content="◀" Width="40" Height="36" Margin="0,4"
                                        FontWeight="Bold" FontSize="14"
                                        Command="{Binding RemoveSelectedCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=SelectedListBox}"
                                        ToolTip="Убрать выбранные"
                                        Style="{StaticResource GlassButton}"
                                        Cursor="Hand"/>
                                <Separator Margin="0,8" Background="#80FFFFFF"/>
                                <Button Content="▶▶" Width="40" Height="36" Margin="0,4"
                                        FontWeight="Bold" FontSize="14"
                                        Command="{Binding AddAllCommand}"
                                        ToolTip="Добавить все"
                                        Style="{StaticResource GlassButton}"
                                        Cursor="Hand"/>
                                <Button Content="◀◀" Width="40" Height="36" Margin="0,4"
                                        FontWeight="Bold" FontSize="14"
                                        Command="{Binding RemoveAllCommand}"
                                        ToolTip="Убрать все"
                                        Style="{StaticResource GlassButton}"
                                        Cursor="Hand"/>
                            </StackPanel>

                            <!-- Правый список: выбранные элементы -->
                            <Border Grid.Column="2" Background="#60FFFFFF" CornerRadius="8" Padding="8" Margin="10,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Выбранные" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <ListBox Grid.Row="1" x:Name="SelectedListBox"
                                             ItemsSource="{Binding SelectedItems}"
                                             SelectionMode="Extended"
                                             Background="Transparent" BorderThickness="0"
                                             Padding="2"
                                             Foreground="{DynamicResource TextPrimaryBrush}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Margin" Value="0,1"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="#80FFFFFF"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#60FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Кнопки ОК/Отмена -->
                <Border Grid.Row="2" Background="{DynamicResource GlassBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,12,12"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✅ OK" Click="Ok_Click"
                                Style="{StaticResource PrimaryGlassButton}"
                                IsDefault="True" Margin="0,0,10,0" Width="100"/>
                        <Button Content="❌ Отмена" Click="Cancel_Click"
                                Style="{StaticResource SecondaryGlassButton}"
                                IsCancel="True" Width="110"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
