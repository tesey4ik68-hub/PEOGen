<UserControl x:Class="AGenerator.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:AGenerator.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="750">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== ЛЕВАЯ КОЛОНКА: МЕНЮ ==================== -->
        <Border Grid.Column="0"
                Background="{DynamicResource GlassBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,1,0"
                Margin="0">
            <StackPanel Margin="12,20,12,20">

                <!-- Заголовок меню -->
                <TextBlock Text="⚙️ Настройки"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="8,0,0,20"/>

                <!-- Пункт: Дизайн -->
                <Border x:Name="DesignMenuBorder"
                        Background="{DynamicResource GlassBorderBrush}"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,4"
                        Cursor="Hand"
                        MouseLeftButtonDown="CategoryMenu_MouseLeftButtonDown"
                        Tag="Design">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎨"
                                   FontSize="16"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Дизайн"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Design">
                                    <Setter Property="Background" Value="{DynamicResource GlassBorderBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Пункт: Акты и реестры -->
                <Border x:Name="DocumentsMenuBorder"
                        Background="{DynamicResource GlassBorderBrush}"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,4,0,0"
                        Cursor="Hand"
                        MouseLeftButtonDown="CategoryMenu_MouseLeftButtonDown"
                        Tag="Documents">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋"
                                   FontSize="16"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Акты и реестры"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="Documents">
                                    <Setter Property="Background" Value="{DynamicResource GlassBorderBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

            </StackPanel>
        </Border>

        <!-- ==================== ПРАВАЯ КОЛОНКА: КОНТЕНТ ==================== -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,20,20">

                <!-- ==================== РАЗДЕЛ: ДИЗАЙН ==================== -->
                <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Design}">

                    <!-- Заголовок раздела -->
                    <TextBlock Text="🎨 Тема оформления"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Пресеты тем -->
                    <TextBlock Text="Готовые пресеты:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <ItemsControl x:Name="ThemesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectThemePresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,8"
                                        Padding="10,8"
                                        BorderThickness="2"
                                        BorderBrush="#DDD"
                                        Background="White"
                                        Cursor="Hand"
                                        Width="130"
                                        Height="60"
                                        HorizontalContentAlignment="Left">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8"
                                                                Padding="8">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding PrimaryColor}"
                                                                           TextWrapping="Wrap"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <Border Width="14"
                                                                            Height="14"
                                                                            CornerRadius="3"
                                                                            Background="{Binding PrimaryColor}"
                                                                            Margin="1"/>
                                                                    <Border Width="14"
                                                                            Height="14"
                                                                            CornerRadius="3"
                                                                            Background="{Binding SecondaryColor}"
                                                                            Margin="1"/>
                                                                    <Border Width="14"
                                                                            Height="14"
                                                                            CornerRadius="3"
                                                                            Background="{Binding AccentColor}"
                                                                            Margin="1"/>
                                                                    <Border Width="14"
                                                                            Height="14"
                                                                            CornerRadius="3"
                                                                            Background="#FFFFFF"
                                                                            Margin="1"
                                                                            BorderBrush="#CCC"
                                                                            BorderThickness="1"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#999"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Разделитель -->
                    <Border Height="1"
                            Background="#E0E0E0"
                            Margin="0,12"/>

                    <!-- Ручная настройка цветов -->
                    <TextBlock Text="✏️ Ручная настройка цветов"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,14,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Основной цвет -->
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Основной:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,6"/>
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding SelectPrimaryColorCommand}"
                                    Width="36"
                                    Height="36"
                                    Margin="0,4,8,4"
                                    Cursor="Hand"
                                    ToolTip="Выбрать основной цвет">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{Binding PrimaryColor}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1">
                                                        <TextBlock Text="🎨"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding PrimaryColorLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Вторичный цвет -->
                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Вторичный:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,6"/>
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding SelectSecondaryColorCommand}"
                                    Width="36"
                                    Height="36"
                                    Margin="0,4,8,4"
                                    Cursor="Hand"
                                    ToolTip="Выбрать вторичный цвет">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{Binding SecondaryColor}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1">
                                                        <TextBlock Text="🎨"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding SecondaryColorLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Акцентный цвет -->
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Акцент:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,6"/>
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding SelectAccentColorCommand}"
                                    Width="36"
                                    Height="36"
                                    Margin="0,4,8,4"
                                    Cursor="Hand"
                                    ToolTip="Выбрать цвет акцента">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{Binding AccentColor}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1">
                                                        <TextBlock Text="🎨"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding AccentColorLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Цвет текста -->
                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Цвет текста:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,6"/>
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding SelectTextColorCommand}"
                                    Width="36"
                                    Height="36"
                                    Margin="0,4,8,4"
                                    Cursor="Hand"
                                    ToolTip="Выбрать цвет текста">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{Binding TextColor}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1">
                                                        <TextBlock Text="🎨"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding TextColorLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Разделитель -->
                    <Border Height="1"
                            Background="#E0E0E0"
                            Margin="0,12"/>

                    <!-- Кнопки действий -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="🔄 Сбросить"
                                Command="{Binding ResetThemeCommand}"
                                Style="{DynamicResource SecondaryGlassButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="✅ Применить"
                                Command="{Binding ApplyThemeCommand}"
                                Style="{DynamicResource PrimaryGlassButton}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ==================== РАЗДЕЛ: АКТЫ И РЕЕСТРЫ ==================== -->
                <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Documents}">

                    <!-- Заголовок раздела -->
                    <TextBlock Text="📋 Настройки документов"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Подзаголовок -->
                    <TextBlock Text="Параметры формирования приложений и реестров актов"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <!-- Карточка: Порядок приложений -->
                    <Border Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📑 Порядок приложений"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Определите порядок и состав разделов в поле «Приложения» акта"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <!-- Список порядка приложений -->
                            <ItemsControl ItemsSource="{Binding ApplicationOrder}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource GlassBorderBrush}"
                                                CornerRadius="8"
                                                Padding="10,8"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Чекбокс включения -->
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>

                                                <!-- Номер порядка -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Order, StringFormat={}{0}.}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Width="24"
                                                           TextAlignment="Center"
                                                           Margin="0,0,8,0"/>

                                                <!-- Отображаемое имя -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DisplayName}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>

                                                <!-- Кнопка Вверх -->
                                                <Button Grid.Column="3"
                                                        Content="▲"
                                                        Width="32"
                                                        Height="28"
                                                        FontSize="10"
                                                        Cursor="Hand"
                                                        Margin="4,0"
                                                        Command="{Binding DataContext.MoveOrderUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="{DynamicResource GlassBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="6">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Кнопка Вниз -->
                                                <Button Grid.Column="4"
                                                        Content="▼"
                                                        Width="32"
                                                        Height="28"
                                                        FontSize="10"
                                                        Cursor="Hand"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.MoveOrderDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="{DynamicResource GlassBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="6">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Подсказка -->
                            <TextBlock Text="Используйте кнопки ▲▼ для изменения порядка. Снимите чекбокс, чтобы исключить раздел."
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Маска итогового номера акта -->
                    <Border Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🔢 Маска итогового номера акта"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Настройте формирование итогового номера акта по аналогии с VBA (мс1..мс12). Нечётные сегменты — текст, чётные — поля акта."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <!-- Сетка сегментов 6 строк x 4 колонки -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Сегмент 1 (текст) + Сегмент 2 (поле) -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Сегмент 1" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ActNumberMask.Segment1Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Сегмент 2" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment2Field}" FontSize="12" Margin="4,2"/>

                                <!-- Row 1: Сегмент 3 (текст) + Сегмент 4 (поле) -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Сегмент 3" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ActNumberMask.Segment3Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Сегмент 4" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment4Field}" FontSize="12" Margin="4,2"/>

                                <!-- Row 2: Сегмент 5 (текст) + Сегмент 6 (поле) -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Сегмент 5" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ActNumberMask.Segment5Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Сегмент 6" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment6Field}" FontSize="12" Margin="4,2"/>

                                <!-- Row 3: Сегмент 7 (текст) + Сегмент 8 (поле) -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Сегмент 7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ActNumberMask.Segment7Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Сегмент 8" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="3" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment8Field}" FontSize="12" Margin="4,2"/>

                                <!-- Row 4: Сегмент 9 (текст) + Сегмент 10 (поле) -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Сегмент 9" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ActNumberMask.Segment9Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Сегмент 10" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="4" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment10Field}" FontSize="12" Margin="4,2"/>

                                <!-- Row 5: Сегмент 11 (текст) + Сегмент 12 (поле) -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Сегмент 11" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ActNumberMask.Segment11Text, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Margin="4,2"/>

                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Сегмент 12" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,4"/>
                                <ComboBox Grid.Row="5" Grid.Column="3" ItemsSource="{Binding ActFields}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ActNumberMask.Segment12Field}" FontSize="12" Margin="4,2"/>
                            </Grid>

                            <!-- Предпросмотр -->
                            <Border Background="{DynamicResource GlassBorderBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,0">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Пример итогового номера:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ActNumberPreview}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Лимит документов для реестра -->
                    <Border Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📊 Лимит документов для реестра"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Ограничение количества документов, включаемых в реестр актов"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="⚙️ Будет доступно в следующем обновлении"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Правила формирования раздела "Приложения" -->
                    <Border Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📎 Правила формирования раздела &quot;Приложения&quot;"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Настройка автоматического формирования раздела приложений в актах"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="⚙️ Будет доступно в следующем обновлении"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
