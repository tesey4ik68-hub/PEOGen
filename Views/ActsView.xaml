<UserControl x:Class="AGenerator.Views.ActsView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:sys="clr-namespace:System;assembly=mscorlib"
              xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
              mc:Ignorable="d"
              d:DesignHeight="600" d:DesignWidth="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар (Glass) -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Новый акт" Command="{Binding AddNewActCommand}"
                        Style="{StaticResource PrimaryGlassButton}" Margin="0,0,8,0"/>
                <Button Content="🗑️ Удалить" Command="{Binding DeleteSelectedActCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="📑 Генерация" Command="{Binding GenerateDocumentCommand}"
                        CommandParameter="{Binding SelectedAct}"
                        Style="{StaticResource PrimaryGlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="📑 Генерировать выбранные" Command="{Binding GenerateSelectedActsCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="☑ Выбрать все" Command="{Binding SelectAllCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="☐ Снять выбор" Command="{Binding DeselectAllCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>

                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource GlassTextBox}"
                         ToolTip="Поиск по названию работ или номеру акта"/>
            </StackPanel>
        </Border>

        <!-- Таблица актов -->
        <DataGrid x:Name="MyDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Acts}"
                  SelectedItem="{Binding SelectedAct}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  MinRowHeight="40"
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="False"
                  behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True"
                  behaviors:DataGridCellTooltipBehavior.IsEnabled="True"
                  behaviors:DataGridAutoRowHeightBehavior.IsEnabled="True">

                <DataGrid.Resources>
                    <!-- Стиль для TextBlock в ячейках — перенос текста -->
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="Padding" Value="3,2"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>

                    <!-- Стиль для редактирования TextBox (Excel-стиль: перенос текста, без рамки) -->
                    <Style x:Key="WrapTextBoxStyle" TargetType="TextBox">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="AcceptsReturn" Value="True"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="3,2"/>
                        <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="VerticalContentAlignment" Value="Top"/>
                        <Setter Property="Height" Value="NaN"/>
                        <Setter Property="MinHeight" Value="35"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="➕ Добавить строку" Command="{Binding AddNewActCommand}"/>
                        <MenuItem Header="📋 Дублировать строку" Command="{Binding DuplicateActCommand}" CommandParameter="{Binding SelectedAct}"/>
                        <MenuItem Header="🗑️ Удалить строку" Command="{Binding DeleteSelectedActCommand}"/>
                        <Separator/>
                        <MenuItem Header="🔄 Обновить" Command="{Binding RefreshCommand}"/>
                        <Separator/>
                        <MenuItem Header="📑 Сгенерировать документ" Command="{Binding GenerateDocumentCommand}" CommandParameter="{Binding SelectedAct}"/>
                        <MenuItem Header="📑 Сгенерировать выбранные" Command="{Binding GenerateSelectedActsCommand}"/>
                        <Separator/>
                        <MenuItem Header="☑ Выбрать все" Command="{Binding SelectAllCommand}"/>
                        <MenuItem Header="☐ Снять выбор" Command="{Binding DeselectAllCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <!-- ==================== 1. ПЕЧАТЬ (CheckBox) ==================== -->

                    <DataGridTemplateColumn Header="Печать" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelectedForBatch, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 2. № П/П ==================== -->

                    <DataGridTemplateColumn Header="№ п/п" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SortOrder}" VerticalAlignment="Center" Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 3. № АКТА (было "Итог №") ==================== -->

                    <DataGridTemplateColumn Header="№ акта" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FinalActNumber}" VerticalAlignment="Center" Margin="3" Foreground="#555" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 4. ТИП ==================== -->

                    <DataGridTemplateColumn Header="Тип" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>АОСР</sys:String>
                                            <sys:String>АООК</sys:String>
                                            <sys:String>АОИО</sys:String>
                                            <sys:String>АВК</sys:String>
                                            <sys:String>АГИ</sys:String>
                                            <sys:String>АИИО</sys:String>
                                            <sys:String>АОГРОКС</sys:String>
                                            <sys:String>АОСР3</sys:String>
                                            <sys:String>АОУСИТО</sys:String>
                                            <sys:String>АПрОб</sys:String>
                                            <sys:String>АРООКС</sys:String>
                                            <sys:String>ОтЭфД</sys:String>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 5. НОМЕР АКТА ==================== -->

                    <DataGridTemplateColumn Header="Номер акта" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActNumber}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ActNumber, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 6. НАИМЕНОВАНИЕ РАБОТ ==================== -->

                    <DataGridTemplateColumn Header="Наименование работ" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="3" MaxWidth="190" ToolTip="{Binding WorkName, Mode=OneWay}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding WorkName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource WrapTextBoxStyle}"
                                         MaxHeight="80"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 7. ТИП ИНТЕРВАЛА ==================== -->

                    <DataGridTemplateColumn Header="Тип интервала" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IntervalType}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding IntervalType, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>на интервале</sys:String>
                                            <sys:String>в камере</sys:String>
                                            <sys:String>в колодце</sys:String>
                                            <sys:String>в точке</sys:String>
                                            <sys:String>на отметке</sys:String>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 8. ИНТЕРВАЛ ==================== -->

                    <DataGridTemplateColumn Header="Интервал" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Interval}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Interval, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 9. ОБЪЁМ ==================== -->

                    <DataGridTemplateColumn Header="Объём" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Volume}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 10. ЕД.ИЗМ. ==================== -->

                    <DataGridTemplateColumn Header="Ед.изм." Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UnitOfMeasure}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding UnitOfMeasure, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 11. ДАТА НАЧАЛА ==================== -->

                    <DataGridTemplateColumn Header="Дата начала" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkStartDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding WorkStartDate, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 12. ДАТА ОКОНЧАНИЯ ==================== -->

                    <DataGridTemplateColumn Header="Дата окончания" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkEndDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding WorkEndDate, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 13. ДАТА АКТА ==================== -->

                    <DataGridTemplateColumn Header="Дата акта" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding ActDate, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 14. АВТОНАЗВАНИЕ ==================== -->

                    <DataGridTemplateColumn Header="Автоназвание" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AutoWorkName}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="3" MaxWidth="210" Foreground="#444"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 15. ПОСЛЕДУЮЩИЕ РАБОТЫ ==================== -->

                    <DataGridTemplateColumn Header="Последующие работы" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SubsequentWork}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="110"
                                               Foreground="#888"/>
                                    <Button Content="🔍"
                                            Command="{Binding DataContext.SelectSubsequentWorkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Выбор последующих работ"
                                            Margin="2,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 16. МАТЕРИАЛЫ ==================== -->

                    <DataGridTemplateColumn Header="Материалы" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding MaterialsDisplay}"
                                        Command="{Binding DataContext.EditMaterialsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать материалы акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 17. СХЕМЫ ==================== -->

                    <DataGridTemplateColumn Header="Схемы" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding SchemasDisplay}"
                                        Command="{Binding DataContext.EditSchemasCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать схемы акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 18. ПРОЕКТ ==================== -->

                    <DataGridTemplateColumn Header="Проект" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding ProjectDocsDisplay}"
                                        Command="{Binding DataContext.EditProjectDocsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать проектную документацию акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 19. НОРМАТИВЫ ==================== -->

                    <DataGridTemplateColumn Header="Нормативы" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding StandardReferenceDisplay}"
                                        Command="{Binding DataContext.EditRegulatoryDocsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать нормативные документы акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 20. ПОДПИСАНТЫ (новый столбец) ==================== -->

                    <DataGridTemplateColumn Header="Подписанты" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding SignatoriesDisplay}"
                                        Command="{Binding DataContext.EditSignatoriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать подписантов акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 21. ОРГАНИЗАЦИИ (новый столбец) ==================== -->

                    <DataGridTemplateColumn Header="Организации" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding OrganizationsDisplay}"
                                        Command="{Binding DataContext.EditOrganizationsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Редактировать организации акта"
                                        Style="{StaticResource GlassButton}"
                                        HorizontalContentAlignment="Center"
                                        Margin="3"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 22. СВЯЗЬ ИД ==================== -->

                    <DataGridTemplateColumn Header="Связь ИД" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RelatedAct.WorkName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableActsForLink, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding RelatedActId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="WorkName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 23. СВЯЗЬ АООК ==================== -->

                    <DataGridTemplateColumn Header="Связь АООК" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RelatedAook.WorkName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableActsForLink, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding RelatedAookId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="WorkName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 24. ПРИЛОЖЕНИЯ ВРУЧНУЮ ==================== -->

                    <DataGridTemplateColumn Header="Приложения вручную" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Appendix}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Appendix, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 25. ЭКЗ. ==================== -->

                    <DataGridTemplateColumn Header="Экз." Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CopiesCount}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding CopiesCount, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 26. ДОП. СВЕДЕНИЯ ==================== -->

                    <DataGridTemplateColumn Header="Доп. сведения" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AdditionalInfo}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding AdditionalInfo, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 27. % НАГРУЗКИ ==================== -->

                    <DataGridTemplateColumn Header="% нагрузки" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LoadPercentage}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding LoadPercentage, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 28. УСЛОВИЯ НАГРУЖЕНИЯ ==================== -->

                    <DataGridTemplateColumn Header="Условия нагружения" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullLoadConditions}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding FullLoadConditions, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== 29. СТАТУС ==================== -->

                    <DataGridTemplateColumn Header="Статус" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource WrapTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
    </Grid>
</UserControl>