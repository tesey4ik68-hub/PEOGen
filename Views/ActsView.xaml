<UserControl x:Class="AGenerator.Views.ActsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар (Glass) -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Новый акт" Command="{Binding AddNewActCommand}"
                        Style="{StaticResource PrimaryGlassButton}" Margin="0,0,8,0"/>
                <Button Content="🗑️ Удалить" Command="{Binding DeleteSelectedActCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        IsEnabled="{Binding SelectedAct, Converter={StaticResource NullToBoolConverter}}"
                        Margin="0,0,8,0"/>
                <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                        Style="{StaticResource GlassButton}"
                        Margin="0,0,8,0"/>
                <Button Content="📑 Генерация" Command="{Binding GenerateDocumentCommand}"
                        CommandParameter="{Binding SelectedAct}"
                        Style="{StaticResource PrimaryGlassButton}"
                        IsEnabled="{Binding SelectedAct, Converter={StaticResource NullToBoolConverter}}"
                        Margin="0,0,8,0"/>

                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource GlassTextBox}"
                         ToolTip="Поиск по названию работ или номеру акта"/>
            </StackPanel>
        </Border>

        <!-- Таблица актов с горизонтальным скроллом -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="MyDataGrid"
                      ItemsSource="{Binding Acts}"
                      SelectedItem="{Binding SelectedAct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      AlternatingRowBackground="#F9F9F9"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      HorizontalScrollBarVisibility="Disabled"
                      behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True">

                <DataGrid.Resources>
                    <!-- Стиль для TextBlock в ячейках — перенос текста + автоматическая высота -->
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- ==================== ОСНОВНЫЕ ПОЛЯ ==================== -->

                    <!-- 1. Тип акта (текст → ComboBox при редактировании) -->
                    <DataGridTemplateColumn Header="Тип" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>АОСР</sys:String>
                                            <sys:String>АООК</sys:String>
                                            <sys:String>АОИО</sys:String>
                                            <sys:String>АВК</sys:String>
                                            <sys:String>АГИ</sys:String>
                                            <sys:String>АИИО</sys:String>
                                            <sys:String>АОГРОКС</sys:String>
                                            <sys:String>АОСР3</sys:String>
                                            <sys:String>АОУСИТО</sys:String>
                                            <sys:String>АПрОб</sys:String>
                                            <sys:String>АРООКС</sys:String>
                                            <sys:String>ОтЭфД</sys:String>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 2. Номер акта -->
                    <DataGridTextColumn Header="Номер" Width="90"
                                        Binding="{Binding ActNumber, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 3. Итоговый номер (Readonly, вычисляемое) -->
                    <DataGridTextColumn Header="Итог №" Width="110"
                                        Binding="{Binding FinalActNumber}" IsReadOnly="True" Foreground="#555"/>

                    <!-- 4. Дата акта (DatePicker) -->
                    <DataGridTemplateColumn Header="Дата акта" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding ActDate, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 5. Дата начала работ -->
                    <DataGridTemplateColumn Header="Дата начала" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkStartDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding WorkStartDate, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 6. Дата окончания работ -->
                    <DataGridTemplateColumn Header="Дата окончания" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkEndDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                           VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding WorkEndDate, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== НАИМЕНОВАНИЕ И СТРУКТУРА ==================== -->

                    <!-- 7. Наименование работ -->
                    <DataGridTextColumn Header="Наименование работ" Width="200"
                                        Binding="{Binding WorkName, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 8. Автоназвание (Readonly, вычисляемое) -->
                    <DataGridTextColumn Header="Автоназвание" Width="250"
                                        Binding="{Binding AutoWorkName}" IsReadOnly="True" Foreground="#444"/>

                    <!-- 9. Объём -->
                    <DataGridTextColumn Header="Объём" Width="80"
                                        Binding="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 10. Ед.изм. -->
                    <DataGridTextColumn Header="Ед.изм." Width="80"
                                        Binding="{Binding UnitOfMeasure, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- ==================== ИНТЕРВАЛ ==================== -->

                    <!-- 11. Тип интервала (текст → ComboBox при редактировании) -->
                    <DataGridTemplateColumn Header="Тип интервала" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IntervalType}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding IntervalType, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="{x:Type sys:String}">
                                            <sys:String>на интервале</sys:String>
                                            <sys:String>в камере</sys:String>
                                            <sys:String>в колодце</sys:String>
                                            <sys:String>в точке</sys:String>
                                            <sys:String>на отметке</sys:String>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 12. Интервал -->
                    <DataGridTextColumn Header="Интервал" Width="100"
                                        Binding="{Binding Interval, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- ==================== СВЯЗИ ==================== -->

                    <!-- 21. Связь ИД (ComboBox) -->
                    <DataGridTemplateColumn Header="Связь ИД" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RelatedAct.WorkName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableActsForLink, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding RelatedActId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="WorkName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 22. Связь АООК (ComboBox) -->
                    <DataGridTemplateColumn Header="Связь АООК" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RelatedAook.WorkName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableActsForLink, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding RelatedAookId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="WorkName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== КНОПКИ ВЫБОРА КОЛЛЕКЦИЙ ==================== -->

                    <!-- 14. Материалы (текст + кнопка) -->
                    <DataGridTemplateColumn Header="Материалы" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding MaterialsDisplay}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="160"
                                               ToolTip="{Binding MaterialsDisplay}"/>
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditMaterialsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Выбор материалов"
                                            Margin="3,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 15. Схемы (текст + кнопка) -->
                    <DataGridTemplateColumn Header="Схемы" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SchemasDisplay}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="160"
                                               ToolTip="{Binding SchemasDisplay}"/>
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditSchemasCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Исполнительные схемы"
                                            Margin="3,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 16. Проектная документация (текст + кнопка-заглушка) -->
                    <DataGridTemplateColumn Header="Проект" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ProjectDocumentation}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="160"
                                               ToolTip="{Binding ProjectDocumentation}"
                                               Foreground="#888"/>
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditProjectDocsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Проектная / рабочая документация"
                                            Margin="3,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 17. Нормативы (текст + кнопка-заглушка) -->
                    <DataGridTemplateColumn Header="Нормативы" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StandardReference}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="160"
                                               ToolTip="{Binding StandardReference}"
                                               Foreground="#888"/>
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditRegulatoryDocsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Выполнено в соответствии с"
                                            Margin="3,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 18. Протоколы (текст + кнопка) -->
                    <DataGridTemplateColumn Header="Протоколы" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ProtocolsDisplay}" VerticalAlignment="Center"
                                               Margin="3,0" TextWrapping="Wrap" MaxWidth="160"
                                               ToolTip="{Binding ProtocolsDisplay}"/>
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditProtocolsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Результаты экспертиз и испытаний"
                                            Margin="3,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== ПОДПИСАНТЫ (ComboBox по сотрудникам) ==================== -->

                    <!-- 28. СК Заказчика -->
                    <DataGridTemplateColumn Header="СК Заказчика" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CustomerRep.FullName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding CustomerRepId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 29. СК Генподрядчика -->
                    <DataGridTemplateColumn Header="СК Генподрядчика" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GenContractorRep.FullName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding GenContractorRepId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 30. Подрядчик -->
                    <DataGridTemplateColumn Header="Подрядчик" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ContractorRep.FullName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding ContractorRepId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 31. Авторский надзор -->
                    <DataGridTemplateColumn Header="Авторский надзор" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DesignerRep.FullName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding AuthorSupervisionId, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== ДОП. ПОЛЯ ==================== -->

                    <!-- 32. Последующие работы -->
                    <DataGridTemplateColumn Header="Посл. работы" Width="150">
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Width="110" Text="{Binding SubsequentWork, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="🔍" 
                                            Command="{Binding DataContext.SelectSubsequentWorkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}"
                                            Margin="5,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- ==================== ОРГАНИЗАЦИИ (ComboBox из справочника) ==================== -->

                    <!-- Заказчик -->
                    <DataGridTemplateColumn Header="Заказчик" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CustomerOrganization.DisplayName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Organizations, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding CustomerOrganizationId}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Генподрядчик -->
                    <DataGridTemplateColumn Header="Генподрядчик" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GenContractorOrganization.DisplayName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Organizations, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding GenContractorOrganizationId}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Подрядчик -->
                    <DataGridTemplateColumn Header="Подрядчик (орг.)" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ContractorOrganization.DisplayName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Organizations, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding ContractorOrganizationId}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Проектировщик -->
                    <DataGridTemplateColumn Header="Проектировщик (орг.)" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DesignerOrganization.DisplayName}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Organizations, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding DesignerOrganizationId}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- 33. Приложения -->
                    <DataGridTextColumn Header="Приложения" Width="120"
                                        Binding="{Binding Appendix, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 34. Кол-во экз. -->
                    <DataGridTextColumn Header="Экз." Width="50"
                                        Binding="{Binding CopiesCount, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 35. Доп. сведения -->
                    <DataGridTextColumn Header="Доп. сведения" Width="150"
                                        Binding="{Binding AdditionalInfo, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- ==================== БЛОК АООК ==================== -->

                    <!-- 36. % нагрузки -->
                    <DataGridTextColumn Header="% нагрузки" Width="90"
                                        Binding="{Binding LoadPercentage, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 37. Условия полного нагружения -->
                    <DataGridTextColumn Header="Условия нагружения" Width="180"
                                        Binding="{Binding FullLoadConditions, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 38. Статус -->
                    <DataGridTextColumn Header="Статус" Width="100"
                                        Binding="{Binding Status, UpdateSourceTrigger=PropertyChanged}"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
