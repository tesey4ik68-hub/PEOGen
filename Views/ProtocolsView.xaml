<UserControl x:Class="AGenerator.Views.ProtocolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AGenerator.ViewModels"
             xmlns:models="clr-namespace:AGenerator.Models"
             xmlns:converters="clr-namespace:AGenerator.Converters"
             xmlns:behaviors="clr-namespace:AGenerator.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ProtocolsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>

        <!-- Стиль для ячеек с переносом текста -->
        <Style x:Key="WrappingCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Тулбар -->
        <Border Grid.Row="0" Background="{DynamicResource GlassBrush}" CornerRadius="12" Padding="15" Margin="0,0,0,10" Effect="{StaticResource GlassShadow}">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить"
                        Command="{Binding AddNewProtocolCommand}"
                        Style="{StaticResource PrimaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"/>
                <Button Content="✏️ Изменить"
                        Command="{Binding EditSelectedProtocolCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedProtocol, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Удалить"
                        Command="{Binding DeleteSelectedProtocolCommand}"
                        Style="{StaticResource SecondaryGlassButton}"
                        Padding="10,5" Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedProtocol, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🔄 Обновить"
                        Command="{Binding RefreshAsyncCommand}"
                        Style="{StaticResource GlassButton}"
                        Padding="10,5"/>
            </StackPanel>
        </Border>

        <!-- Поиск -->
        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource GlassTextBox}"
                 Margin="0,0,0,10"
                 Padding="5"
                 ToolTip="Поиск по номеру или названию"/>

        <!-- Таблица протоколов -->
        <DataGrid Grid.Row="2"
                  x:Name="ProtocolsDataGrid"
                  ItemsSource="{Binding Protocols}"
                  SelectedItem="{Binding SelectedProtocol}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  SelectionMode="Single"
                  MouseDoubleClick="ProtocolsDataGrid_MouseDoubleClick"
                  MouseLeftButtonUp="ProtocolsDataGrid_MouseLeftButtonUp"
                  behaviors:DataGridAutoSizeColumnsBehavior.IsEnabled="True"
                  Style="{StaticResource GlassDataGrid}">
            <DataGrid.Resources>
                <!-- Стиль для TextBlock в ячейках — перенос текста + автоматическая высота -->
                <Style TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип док." Width="130" Binding="{Binding DocumentTypeDisplay}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="№ протокола" Width="100" Binding="{Binding Number}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="200"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Дата" Width="90" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Лаборатория" Width="150" Binding="{Binding Laboratory}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <DataGridTextColumn Header="Результат" Width="130" Binding="{Binding Result}"
                                    ElementStyle="{StaticResource WrappingCellText}"/>
                <!-- Колонка файла протокола -->
                <DataGridTemplateColumn Header="Файл" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📎"
                                    ToolTip="{Binding FileName, Mode=OneWay}"
                                    Command="{Binding DataContext.OpenProtocolFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Visibility="{Binding FileName, Mode=OneWay, Converter={StaticResource NullToBoolConverter}, ConverterParameter=Inverted}"
                                    Padding="2"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Модальное окно редактирования (Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#CC000000"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Background="{DynamicResource MainGradient}"
                    Width="580"
                    MaxHeight="680"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="25"
                    CornerRadius="15"
                    Margin="20"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    Effect="{StaticResource GlassShadow}">

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Заголовок с кнопкой закрытия -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🧪 Протокол испытаний"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Width="32" Height="32"
                                    FontSize="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Закрыть">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Red"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Text="№ протокола:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProtocol.Number, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="32"/>

                        <TextBlock Text="Тип документа:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ComboBox SelectedItem="{Binding EditingProtocol.DocumentType}" Margin="0,0,0,12"
                                  Style="{StaticResource GlassComboBox}">
                            <models:ProtocolDocType>TestProtocol</models:ProtocolDocType>
                            <models:ProtocolDocType>Conclusion</models:ProtocolDocType>
                        </ComboBox>

                        <TextBlock Text="Наименование испытания:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProtocol.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="32"/>

                        <TextBlock Text="Тип испытаний:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProtocol.Type, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="32"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата:" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" x:Name="ProtocolDateTextBox"
                                     Text="{Binding EditingProtocol.DateText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource GlassTextBox}"
                                     Padding="5" Margin="0,0,5,0"
                                     ToolTip="Введите дату: 13.08.2015, 08.2015 или 2015"/>
                            <Button Grid.Column="2" x:Name="BtnPickProtocolDate" Content="📅" Padding="6,4"
                                    Style="{StaticResource GlassButton}"
                                    Click="BtnPickProtocolDate_Click" ToolTip="Выбрать дату"/>
                            <Popup x:Name="ProtocolDateCalendarPopup"
                                   PlacementTarget="{Binding ElementName=BtnPickProtocolDate}"
                                   Placement="Bottom" StaysOpen="False"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="#F0FFFFFF" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="5">
                                    <Calendar x:Name="ProtocolDateCalendar" SelectedDatesChanged="ProtocolDateCalendar_SelectedDatesChanged"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Text="Лаборатория:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProtocol.Laboratory, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="32"/>

                        <TextBlock Text="Результат:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding EditingProtocol.Result, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"
                                 Margin="0,0,0,12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="32"/>

                        <!-- ==================== ЗОНА ПРИКРЕПЛЕНИЯ ФАЙЛА ПРОТОКОЛА ==================== -->
                        <TextBlock Text="📎 Файл протокола:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border x:Name="ProtocolDropZone"
                                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="2"
                                Padding="15" Margin="0,0,0,12"
                                CornerRadius="5"
                                AllowDrop="True"
                                DragOver="ProtocolDropZone_DragOver"
                                Drop="ProtocolDropZone_Drop"
                                Background="{DynamicResource GlassBrush}">
                            <StackPanel>
                                <TextBlock Text="Перетащите файл сюда или нажмите кнопку:"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" FontSize="12" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📎 Прикрепить протокол"
                                            Command="{Binding AttachProtocolFileCommand}"
                                            Style="{StaticResource GlassButton}"
                                            Padding="10,5" Margin="0,0,10,0"/>
                                    <Button Content="🗑️ Удалить"
                                            Command="{Binding RemoveProtocolFileCommand}"
                                            Style="{StaticResource SecondaryGlassButton}"
                                            Padding="10,5"
                                            Visibility="{Binding HasProtocolFile, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#10B981"
                                           Visibility="{Binding HasProtocolFile, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="✅ Прикреплён: "/>
                                    <Run Text="{Binding EditingProtocol.FileName, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource GlassBrush}"
                                CornerRadius="12"
                                Padding="15"
                                Margin="0,10,0,0"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="💾 Сохранить"
                                        Command="{Binding SaveProtocolCommand}"
                                        Style="{StaticResource PrimaryGlassButton}"
                                        Padding="15,8"
                                        Margin="0,0,10,0"
                                        IsDefault="True"/>
                                <Button Content="❌ Отмена"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource SecondaryGlassButton}"
                                        Padding="15,8"
                                        IsCancel="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
